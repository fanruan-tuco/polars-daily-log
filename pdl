#!/usr/bin/env bash
# ─── Auto Daily Log — unified CLI ────────────────────────────────────
# Usage:
#   ./pdl server {start|stop|restart|status|logs [N]}
#   ./pdl collector {start|stop|restart|status|logs [N]}
#   ./pdl {start|stop|restart|status}       # acts on BOTH
#   ./pdl install                            # run installer
#   ./pdl clean                              # remove pid/log files
# ─────────────────────────────────────────────────────────────────────

set -euo pipefail

# ─── Paths & config ──────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
STATE_DIR="${PDL_STATE_DIR:-$HOME/.auto_daily_log}"
PID_DIR="$STATE_DIR/pids"
LOG_DIR="$STATE_DIR/logs"
mkdir -p "$PID_DIR" "$LOG_DIR"

SERVER_CONFIG="${PDL_SERVER_CONFIG:-$SCRIPT_DIR/config.yaml}"
COLLECTOR_CONFIG="${PDL_COLLECTOR_CONFIG:-$SCRIPT_DIR/collector.yaml}"
SERVER_PORT="${PDL_SERVER_PORT:-8888}"

# Export so subprocesses (mcp_server, cli_query) can resolve data_dir from
# the same config the user set. Without this, those tools fall back to
# ~/.auto_daily_log even when system.data_dir is customised.
export PDL_SERVER_CONFIG="$SERVER_CONFIG"
export PDL_COLLECTOR_CONFIG="$COLLECTOR_CONFIG"

SERVER_PIDFILE="$PID_DIR/server.pid"
SERVER_LOG="$LOG_DIR/server.log"
COLLECTOR_PIDFILE="$PID_DIR/collector.pid"
COLLECTOR_LOG="$LOG_DIR/collector.log"

# ─── Colors ──────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
    BLUE=$'\033[0;34m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
else
    RED=""; GREEN=""; YELLOW=""; BLUE=""; BOLD=""; DIM=""; NC=""
fi

ok()   { echo "${GREEN}✓${NC} $1"; }
warn() { echo "${YELLOW}!${NC} $1"; }
err()  { echo "${RED}✗${NC} $1" >&2; }
info() { echo "${BLUE}→${NC} $1"; }

# ─── Venv activation ─────────────────────────────────────────────────
activate_venv() {
    if [[ ! -f "$VENV_DIR/bin/activate" ]]; then
        err "Virtual env not found at $VENV_DIR"
        err "Run './pdl install' first."
        exit 1
    fi
    # shellcheck disable=SC1091
    source "$VENV_DIR/bin/activate"
}

# ─── Generic process helpers ─────────────────────────────────────────
pid_alive() {
    local pid="$1"
    [[ -z "$pid" ]] && return 1
    kill -0 "$pid" 2>/dev/null
}

read_pid() {
    local pidfile="$1"
    [[ -f "$pidfile" ]] || return 1
    local pid
    pid="$(cat "$pidfile" 2>/dev/null)"
    [[ -n "$pid" ]] || return 1
    echo "$pid"
}

wait_for_port() {
    local port="$1" timeout="${2:-15}"
    local deadline=$(( $(date +%s) + timeout ))
    while (( $(date +%s) < deadline )); do
        if lsof -ti:"$port" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.3
    done
    return 1
}

process_uptime() {
    local pid="$1"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        ps -p "$pid" -o etime= 2>/dev/null | awk '{$1=$1; print}'
    else
        ps -p "$pid" -o etime= 2>/dev/null | awk '{$1=$1; print}'
    fi
}

# ─── Server subcommands ──────────────────────────────────────────────
server_start() {
    if pid="$(read_pid "$SERVER_PIDFILE")" && pid_alive "$pid"; then
        warn "Server already running (PID $pid)"
        return 0
    fi

    [[ -f "$SERVER_CONFIG" ]] || { err "Server config not found: $SERVER_CONFIG"; exit 1; }

    activate_venv
    info "Starting server on port $SERVER_PORT ..."

    cd "$SCRIPT_DIR"
    nohup python -u -m auto_daily_log \
        --config "$SERVER_CONFIG" \
        --port "$SERVER_PORT" \
        > "$SERVER_LOG" 2>&1 &
    local pid=$!
    echo "$pid" > "$SERVER_PIDFILE"

    if wait_for_port "$SERVER_PORT" 15; then
        ok "Server started (PID $pid) — http://127.0.0.1:$SERVER_PORT"
        info "Logs: $SERVER_LOG"
    else
        err "Server failed to bind port $SERVER_PORT within 15s. See log:"
        tail -20 "$SERVER_LOG" >&2
        kill "$pid" 2>/dev/null || true
        rm -f "$SERVER_PIDFILE"
        exit 1
    fi
}

kill_tree() {
    # Kill a parent process and all its descendants (macOS + Linux compatible).
    local root="$1" sig="${2:-TERM}"
    [[ -z "$root" ]] && return 0
    local pids="$root"
    # Collect children via pgrep -P (works on macOS + Linux)
    local queue=("$root") current children
    while ((${#queue[@]} > 0)); do
        current="${queue[0]}"
        queue=("${queue[@]:1}")
        children="$(pgrep -P "$current" 2>/dev/null || true)"
        for c in $children; do
            pids="$pids $c"
            queue+=("$c")
        done
    done
    for p in $pids; do
        kill -"$sig" "$p" 2>/dev/null || true
    done
}

server_stop() {
    local pid
    pid="$(read_pid "$SERVER_PIDFILE" 2>/dev/null || true)"

    if [[ -z "$pid" ]] || ! pid_alive "$pid"; then
        # Fallback: find anything on the port and kill its tree
        local port_pid
        port_pid="$(lsof -ti:"$SERVER_PORT" 2>/dev/null | head -1 || true)"
        if [[ -n "$port_pid" ]]; then
            warn "PID file stale; killing process tree on port $SERVER_PORT (root PID $port_pid)"
            kill_tree "$port_pid" TERM
            sleep 1
            if lsof -ti:"$SERVER_PORT" >/dev/null 2>&1; then
                kill_tree "$port_pid" KILL
            fi
            rm -f "$SERVER_PIDFILE"
            ok "Server stopped"
        else
            info "Server not running"
            rm -f "$SERVER_PIDFILE"
        fi
        return 0
    fi

    info "Stopping server (PID $pid) ..."
    kill_tree "$pid" TERM
    local waited=0
    while pid_alive "$pid" && (( waited < 10 )); do
        sleep 0.5
        waited=$((waited + 1))
    done
    if pid_alive "$pid"; then
        warn "Server didn't stop gracefully; sending SIGKILL to tree"
        kill_tree "$pid" KILL
    fi
    # Final sweep: anything still on port
    if lsof -ti:"$SERVER_PORT" >/dev/null 2>&1; then
        local stragglers
        stragglers="$(lsof -ti:"$SERVER_PORT" 2>/dev/null || true)"
        warn "Killing port stragglers: $stragglers"
        for p in $stragglers; do
            kill -9 "$p" 2>/dev/null || true
        done
    fi
    rm -f "$SERVER_PIDFILE"
    ok "Server stopped"
}

server_status() {
    local pid
    if pid="$(read_pid "$SERVER_PIDFILE")" && pid_alive "$pid"; then
        local uptime
        uptime="$(process_uptime "$pid")"
        ok "${BOLD}Server${NC}    PID $pid  |  port $SERVER_PORT  |  uptime $uptime"
        # Try to hit /api/collectors to confirm it's actually serving
        if NO_PROXY="*" curl -fsS --max-time 2 "http://127.0.0.1:$SERVER_PORT/api/collectors" >/dev/null 2>&1; then
            echo "          ${DIM}HTTP OK — http://127.0.0.1:$SERVER_PORT${NC}"
        else
            echo "          ${YELLOW}HTTP not responding yet${NC}"
        fi
    else
        echo "${DIM}○${NC}  ${BOLD}Server${NC}    stopped"
        return 1
    fi
}

server_logs() {
    local n="${1:-50}"
    [[ -f "$SERVER_LOG" ]] || { err "No server log at $SERVER_LOG"; exit 1; }
    if [[ "$n" == "-f" ]]; then
        tail -f "$SERVER_LOG"
    else
        tail -n "$n" "$SERVER_LOG"
    fi
}

# ─── Collector subcommands ───────────────────────────────────────────
collector_start() {
    if pid="$(read_pid "$COLLECTOR_PIDFILE")" && pid_alive "$pid"; then
        warn "Collector already running (PID $pid)"
        return 0
    fi

    [[ -f "$COLLECTOR_CONFIG" ]] || {
        err "Collector config not found: $COLLECTOR_CONFIG"
        err "Copy collector.yaml.example → collector.yaml and fill in server_url"
        exit 1
    }

    activate_venv
    info "Starting collector (config: $COLLECTOR_CONFIG) ..."

    cd "$SCRIPT_DIR"
    nohup python -u -m auto_daily_log_collector \
        --config "$COLLECTOR_CONFIG" \
        > "$COLLECTOR_LOG" 2>&1 &
    local pid=$!
    echo "$pid" > "$COLLECTOR_PIDFILE"

    # Give it a moment to register
    sleep 2
    if pid_alive "$pid"; then
        ok "Collector started (PID $pid)"
        info "Logs: $COLLECTOR_LOG"
    else
        err "Collector exited immediately. See log:"
        tail -20 "$COLLECTOR_LOG" >&2
        rm -f "$COLLECTOR_PIDFILE"
        exit 1
    fi
}

collector_stop() {
    local pid
    if ! pid="$(read_pid "$COLLECTOR_PIDFILE")" || ! pid_alive "$pid"; then
        info "Collector not running"
        rm -f "$COLLECTOR_PIDFILE"
        return 0
    fi

    info "Stopping collector (PID $pid) ..."
    kill_tree "$pid" TERM
    local waited=0
    while pid_alive "$pid" && (( waited < 10 )); do
        sleep 0.5
        waited=$((waited + 1))
    done
    if pid_alive "$pid"; then
        warn "Collector didn't stop gracefully; sending SIGKILL to tree"
        kill_tree "$pid" KILL
    fi
    rm -f "$COLLECTOR_PIDFILE"
    ok "Collector stopped"
}

collector_status() {
    local pid
    if pid="$(read_pid "$COLLECTOR_PIDFILE")" && pid_alive "$pid"; then
        local uptime
        uptime="$(process_uptime "$pid")"
        ok "${BOLD}Collector${NC} PID $pid  |  uptime $uptime  |  config $(basename "$COLLECTOR_CONFIG")"
    else
        echo "${DIM}○${NC}  ${BOLD}Collector${NC} stopped"
        return 1
    fi
}

collector_logs() {
    local n="${1:-50}"
    [[ -f "$COLLECTOR_LOG" ]] || { err "No collector log at $COLLECTOR_LOG"; exit 1; }
    if [[ "$n" == "-f" ]]; then
        tail -f "$COLLECTOR_LOG"
    else
        tail -n "$n" "$COLLECTOR_LOG"
    fi
}

collector_uninstall() {
    [[ -f "$COLLECTOR_CONFIG" ]] || { err "Collector config not found: $COLLECTOR_CONFIG"; exit 1; }
    activate_venv
    # Stop first
    collector_stop || true
    info "Running collector uninstall ..."
    cd "$SCRIPT_DIR"
    python -m auto_daily_log_collector --config "$COLLECTOR_CONFIG" --uninstall
    ok "Collector uninstalled"
}

# ─── Combined subcommands ────────────────────────────────────────────
all_start() {
    server_start
    if [[ -f "$COLLECTOR_CONFIG" ]]; then
        collector_start
    else
        info "No collector.yaml found — only server started"
    fi
}

all_stop() {
    collector_stop || true
    server_stop || true
}

all_status() {
    server_status || true
    if [[ -f "$COLLECTOR_CONFIG" ]]; then
        collector_status || true
    fi
}

# ─── MCP registration ────────────────────────────────────────────────
_find_claude_cli() {
    # Try common locations for the Claude Code CLI
    for candidate in \
        "claude" \
        "$HOME/.claude/local/claude" \
        "/usr/local/bin/claude" \
        "$HOME/.local/bin/claude"; do
        if command -v "$candidate" &>/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
        if [[ -x "$candidate" ]]; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

MCP_SERVER_NAME="polars-daily-log"

mcp_install() {
    local scope="${1:---scope user}"
    local claude_cli
    if ! claude_cli="$(_find_claude_cli)"; then
        err "Claude Code CLI not found. Install it first:"
        echo "  curl -fsSL https://claude.ai/install.sh | bash"
        echo ""
        echo "Or register manually by adding to ~/.claude/.mcp.json:"
        echo "  {\"mcpServers\":{\"$MCP_SERVER_NAME\":{\"command\":\"$SCRIPT_DIR/pdl\",\"args\":[\"mcp\",\"start\"]}}}"
        exit 1
    fi

    info "Registering MCP server '$MCP_SERVER_NAME' with Claude Code..."
    if "$claude_cli" mcp add "$MCP_SERVER_NAME" $scope -- "$SCRIPT_DIR/pdl" mcp start; then
        ok "MCP server registered ($scope)"
        echo ""
        echo "  Restart Claude Code to pick it up, then try:"
        echo "    \"查一下我昨天的活动记录\""
        echo "    \"帮我把今天的工时提交到 Jira\""
        echo ""
        echo "  To remove:  ./pdl mcp uninstall"
    else
        err "Registration failed. You can add manually to ~/.claude/.mcp.json:"
        echo "  {\"mcpServers\":{\"$MCP_SERVER_NAME\":{\"command\":\"$SCRIPT_DIR/pdl\",\"args\":[\"mcp\",\"start\"]}}}"
    fi
}

mcp_uninstall() {
    local claude_cli
    if ! claude_cli="$(_find_claude_cli)"; then
        err "Claude Code CLI not found. Remove manually from ~/.claude/.mcp.json"
        exit 1
    fi

    info "Removing MCP server '$MCP_SERVER_NAME'..."
    if "$claude_cli" mcp remove "$MCP_SERVER_NAME" 2>/dev/null; then
        ok "MCP server removed"
    else
        warn "Server not found or already removed"
    fi
}

# ─── Install / clean ────────────────────────────────────────────────
do_install() {
    bash "$SCRIPT_DIR/install.sh"
}

# One-shot rebuild: refresh Python deps + rebuild frontend dist + verify.
# Use after pull when dependencies change (adds marked, refactored imports, etc.).
do_build() {
    local restart=0 skip_py=0 skip_fe=0
    while (($# > 0)); do
        case "$1" in
            --restart)     restart=1 ;;
            --no-python)   skip_py=1 ;;
            --no-frontend) skip_fe=1 ;;
            *) err "Unknown build option: $1"; exit 2 ;;
        esac
        shift
    done

    # Release/user mode: no source tree to build against. Frontend ships
    # prebuilt in the wheel, Python installed from wheel (not editable).
    # Detect via frontend sources (only dev clones carry web/frontend/src/).
    if [[ ! -d "$SCRIPT_DIR/web/frontend/src" ]]; then
        warn "Release mode detected — 'build' is a dev-only command."
        info "To upgrade installed version, run: ./pdl update apply"
        info "To check for updates,          run: ./pdl update check"
        exit 0
    fi

    [[ -d "$VENV_DIR" ]] || { err "Virtual env missing. Run './pdl install' first."; exit 1; }
    activate_venv

    local platform
    case "$(uname -s)" in
        Darwin) platform="macos" ;;
        Linux)  platform="linux" ;;
        MINGW*|MSYS*|CYGWIN*)
            err "Native Windows not supported by this script. Use WSL2 + run './pdl build' inside."
            exit 1 ;;
        *) err "Unsupported platform: $(uname -s)"; exit 1 ;;
    esac

    if (( ! skip_py )); then
        info "Refreshing Python deps (${platform}) ..."
        pip install --upgrade pip -q 2>/dev/null || true
        pip install -e ".[$platform]" -q 2>&1 | tail -3
        # Smoke-test core imports (same list install.sh verifies)
        python -c "import aiosqlite, sqlite_vec, fastapi, uvicorn, httpx, apscheduler, pydantic, yaml, imagehash, PIL" \
            2>/dev/null && ok "Python core imports OK" \
            || { err "Missing Python dep after install — check 'pip install -e .[$platform]' output above"; exit 1; }
    fi

    if (( ! skip_fe )); then
        local fe_dir="$SCRIPT_DIR/web/frontend"
        [[ -d "$fe_dir" ]] || { err "Frontend dir not found: $fe_dir"; exit 1; }
        command -v node >/dev/null 2>&1 || { err "Node.js not installed. Install Node 18+ first."; exit 1; }

        # Reinstall node_modules only if package-lock is newer than node_modules
        if [[ ! -d "$fe_dir/node_modules" ]] || [[ "$fe_dir/package-lock.json" -nt "$fe_dir/node_modules" ]]; then
            info "Installing npm deps ..."
            (cd "$fe_dir" && npm install --silent 2>&1 | tail -3)
        else
            ok "npm deps up-to-date (node_modules newer than lockfile)"
        fi

        info "Building frontend ..."
        (cd "$fe_dir" && npm run build 2>&1 | tail -3)
        ok "Frontend built: $fe_dir/dist/"

        # Clean the wheel-staging dist. It's only meant to exist during
        # scripts/release.sh (to be packed into the wheel) and is .gitignored.
        # When left behind from a past release attempt it shadows the freshly
        # built dev dist and silently serves stale JS — we burned two hours
        # on exactly that today. Wipe it on every dev build so it can't.
        local staged_dist="$SCRIPT_DIR/auto_daily_log/frontend_dist"
        if [[ -d "$staged_dist" ]]; then
            rm -rf "$staged_dist"
            ok "Cleaned stale wheel-staging dist ($staged_dist)"
        fi
    fi

    if (( restart )); then
        info "Restarting server ..."
        server_stop || true
        server_start
    else
        warn "Server not restarted. Run './pdl server restart' to pick up backend changes, or re-run with --restart"
    fi
}

do_clean() {
    info "Removing pid & log files ..."
    rm -f "$SERVER_PIDFILE" "$COLLECTOR_PIDFILE"
    rm -f "$SERVER_LOG" "$COLLECTOR_LOG"
    ok "Cleaned $STATE_DIR/{pids,logs}/"
}

# ─── Usage ───────────────────────────────────────────────────────────
usage() {
    cat <<EOF
${BOLD}Polars Daily Log — CLI${NC}

${BOLD}USAGE${NC}
  ./pdl <component> <action> [options]
  ./pdl <action>                 (applies to both server + collector)

${BOLD}COMPONENTS${NC}
  server       the central web server
  collector    the local activity collector

${BOLD}ACTIONS${NC}
  start        start the process (daemon)
  stop         stop the process
  restart      stop + start
  status       show PID, uptime, health
  logs [N]     show last N lines (default 50); pass -f to tail follow

${BOLD}TOP-LEVEL${NC}
  start        start both server & collector
  stop         stop both
  restart      stop both + start both
  status       status of both
  install      run install.sh (first-time full setup)
  build        refresh deps + rebuild frontend (use after pull)
               options: --restart, --no-python, --no-frontend
  mcp install  register MCP server with Claude Code (auto-detects CLI)
  mcp uninstall remove MCP server from Claude Code
  mcp start    run MCP server (stdio transport, called by agent — not manual)
  query        query local data (activities/worklogs/commits/issues)
               ./pdl query activities --date 2026-04-16 --format json
               ./pdl query worklogs --issue PDL-42
               ./pdl query commits --date 2026-04-16 --format table
               ./pdl query issues --all-issues
  update       check for / apply self-updates from GitHub Releases
               ./pdl update check                  # is there a newer version?
               ./pdl update apply --target-version X --wheel-url URL
               ./pdl update list-backups
               ./pdl update rollback --backup ID
               ./pdl update prune --keep 3
  clean        remove pid / log files
  help         show this message

${BOLD}COLLECTOR EXTRAS${NC}
  ./pdl collector uninstall      deregister on server + wipe local state

${BOLD}ENV OVERRIDES${NC}
  PDL_SERVER_PORT=8888           server listen port
  PDL_SERVER_CONFIG=...          path to config.yaml
  PDL_COLLECTOR_CONFIG=...       path to collector.yaml
  PDL_STATE_DIR=~/.auto_daily_log  where pid/log live

${BOLD}EXAMPLES${NC}
  ./pdl start                    start everything
  ./pdl server logs -f           tail server log
  ./pdl collector status
  PDL_SERVER_PORT=9000 ./pdl server start
EOF
}

# ─── Dispatcher ──────────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        server)
            local action="${1:-status}"; shift || true
            case "$action" in
                start)   server_start ;;
                stop)    server_stop ;;
                restart) server_stop; server_start ;;
                status)  server_status ;;
                logs)    server_logs "${1:-50}" ;;
                *)       err "Unknown server action: $action"; exit 2 ;;
            esac
            ;;
        collector)
            local action="${1:-status}"; shift || true
            case "$action" in
                start)     collector_start ;;
                stop)      collector_stop ;;
                restart)   collector_stop; collector_start ;;
                status)    collector_status ;;
                logs)      collector_logs "${1:-50}" ;;
                uninstall) collector_uninstall ;;
                *)         err "Unknown collector action: $action"; exit 2 ;;
            esac
            ;;
        mcp)
            local action="${1:-start}"; shift || true
            case "$action" in
                start)
                    activate_venv
                    exec python -m auto_daily_log.mcp_server
                    ;;
                install)
                    mcp_install "$@"
                    ;;
                uninstall)
                    mcp_uninstall
                    ;;
                *) err "Unknown mcp action: $action"; usage; exit 2 ;;
            esac
            ;;
        start)    all_start ;;
        stop)     all_stop ;;
        restart)  all_stop; sleep 1; all_start ;;
        status)   all_status ;;
        install)  do_install ;;
        build)    do_build "$@" ;;
        query)
            activate_venv
            python -m auto_daily_log.cli_query "$@"
            ;;
        update)
            local action="${1:-check}"; shift || true
            activate_venv
            case "$action" in
                check)         python -m auto_daily_log.updater check "$@" ;;
                apply)         python -m auto_daily_log.updater apply "$@" ;;
                rollback)      python -m auto_daily_log.updater rollback "$@" ;;
                list-backups)  python -m auto_daily_log.updater list-backups ;;
                prune)         python -m auto_daily_log.updater prune "$@" ;;
                *)             err "Unknown update action: $action"; exit 2 ;;
            esac
            ;;
        clean)    do_clean ;;
        help|-h|--help) usage ;;
        *)
            err "Unknown command: $cmd"
            echo ""
            usage
            exit 2
            ;;
    esac
}

main "$@"
