server:
  port: 8888
  host: "0.0.0.0"

monitor:
  enabled: true   # false 则为纯 server 模式（不采集本机，只接收远程 collector 数据）
  interval_sec: 30
  ocr_enabled: false
  ocr_engine: auto
  screenshot_retention_days: 7
  privacy:
    blocked_apps: []
    blocked_urls: []
  phash_enabled: true
  phash_threshold: 10
  idle_threshold_sec: 180
  # hostile_apps_applescript / hostile_apps_screenshot 的默认值在
  # auto_daily_log/config.py:MonitorConfig 里。
  # 默认已包含企业微信/微信等"反自动化"app。
  # 需要覆盖时在此添加（完整替换默认列表）：
  # hostile_apps_applescript: [wechat, wecom, 企业微信, 微信, wechatwork, wechatappex]
  # hostile_apps_screenshot: []

git:
  repos: []

jira:
  server_url: ""
  pat: ""

llm:
  engine: openai_compat   # openai_compat | anthropic | ollama
  openai_compat:
    api_key: ""
    model: "moonshot-v1-8k"
    base_url: "https://api.moonshot.cn/v1"
  anthropic:
    api_key: ""
    model: "claude-sonnet-4-20250514"
    base_url: "https://api.anthropic.com"
  ollama:
    model: "llama3"
    base_url: "http://localhost:11434"

scheduler:
  enabled: true
  trigger_time: "18:00"

auto_approve:
  enabled: true
  trigger_time: "21:30"

embedding:
  enabled: true
  model: ""
  dimensions: 1024

system:
  language: "zh"
  data_retention_days: 90
  data_dir: ""  # 留空默认 ~/.auto_daily_log，可改为如 /opt/auto_daily_log/data
  activity_retention_days: 7   # 活动记录保留天数，超过自动移入回收站
  recycle_retention_days: 30   # 回收站保留天数，超过永久删除
