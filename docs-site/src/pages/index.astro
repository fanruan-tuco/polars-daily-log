        </span>
        <span>Polars Daily Log</span>
      </a>
      <nav class="nav-center">
        <a href="#install">安装</a>
        <a href="#features">功能</a>
        <a href="#pipeline">运作方式</a>
        <a href="#faq">FAQ</a>
        <a href={`${base}/help`}>帮助文档</a>
        <a href={`${repoUrl}/blob/master/CHANGELOG.md`} target="_blank" rel="noopener">更新日志</a>
      </nav>
      <a class="nav-cta" href={releaseUrl} target="_blank" rel="noopener">
        下载 v{version}
      </a>
    </div>
  </header>

  <main>
    <!-- HERO ─────────────────────────────────────────────────── -->
