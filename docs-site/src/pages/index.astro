---
import Base from "../layouts/Base.astro";
import fs from "node:fs";
import path from "node:path";

const base = import.meta.env.BASE_URL;
const repoUrl = "https://github.com/Conner2077/polars-daily-log";
const releaseUrl = `${repoUrl}/releases/latest`;

// Read the current version from the repo root's VERSION file (written by
// release.sh) or fall back to pyproject.toml so the landing page stays in
// sync without manual edits.
let version = "latest";
try {
  const root = path.resolve(process.cwd(), "..");
  const versionFile = path.join(root, "VERSION");
  const pyproject = path.join(root, "pyproject.toml");
  if (fs.existsSync(versionFile)) {
    version = fs.readFileSync(versionFile, "utf8").trim();
  } else if (fs.existsSync(pyproject)) {
    const m = fs.readFileSync(pyproject, "utf8").match(/^version\s*=\s*"([^"]+)"/m);
    if (m) version = m[1];
  }
} catch (e) { /* keep default */ }

const features = [
  {
    tag: "本地优先",
    title: "数据从不离开你的机器",
    body: "不是 SaaS，也不多租户。你自己开一个 server，一台 hub + 几台 collector。朋友之间各装一套，互不相通。",
  },
  {
    tag: "多设备汇总",
    title: "MacBook + 工作台式 + Linux 一并收",
    body: "Collector 跨平台（macOS / Linux / Windows），统一 HTTP 协议推给 hub。一个人的多台设备自动汇总。",
  },
  {
    tag: "AI-native 管线",
    title: "活动级 + 日级双层 LLM 摘要",
    body: "每条活动先 LLM 做语义压缩，傍晚再聚合成当日日志草稿。支持 Claude、OpenAI 兼容、Ollama 本地。",
  },
  {
    tag: "Jira 一键推",
    title: "LLM 总结 → 自动审批 → worklog",
    body: "原汁原味全量记录，二次加工按目的输出。筛过的工时草稿一键推到 Jira；回顾反思看完整时间线。",
  },
];

const pipeline = [
  { num: "01", title: "采集", body: "Collector 抓前台活动（app、窗口标题、URL、OCR）和 Git commits。原汁原味，不预筛。" },
  { num: "02", title: "总结", body: "每条活动先过 LLM 做语义压缩，傍晚合并成当日工作日志草稿。" },
  { num: "03", title: "审批", body: "按「适合提交 Jira」的标准筛；筛出来的才进 worklog。原始数据完整保留。" },
  { num: "04", title: "提交", body: "一键推到你的 Jira worklog。兼容 fanruan Jira 的 emoji / 编码坑。" },
];

const faqs = [
  {
    q: "会上传我的数据吗？",
    a: "不会。所有数据都留在你自己机器上。Server 端就是你自己开的一个服务，一人一套，朋友之间互不相通。",
  },
  {
    q: "Windows 能用吗？",
    a: "Collector 的 Windows 支持还在完善（CI 矩阵标记为 experimental）。macOS / Linux 是一线支持。",
  },
  {
    q: "一定要联网用 LLM API 吗？",
    a: "不必。除了 Claude / OpenAI 兼容 API 之外，也支持 Ollama 本地模型。完全离线也能出每日总结。",
  },
  {
    q: "和团队版工具（Reclaim、Timely、RescueTime）有什么区别？",
    a: "它们是 SaaS 多租户，这是单人多设备本地工具。如果你要团队 dashboard，这不适合你。",
  },
];
---

<Base>
